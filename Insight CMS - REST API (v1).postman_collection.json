					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "<JWT_TOKEN>",
							"type": "string",
							"description": "JWT token for authorization. The token is required for accessing protected endpoints."
						}
					]
				},
				"method": "POST",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "default",
						"description": "Indicates that the response should be in JSON format."
					}
				],
				"body": {
					"mode": "formdata",
					"formdata": [
						{
							"key": "email",
							"value": "admin@mail.com",
							"type": "default",
							"description": "The email address of the user attempting to log in. Example: 'admin@mail.com'."
						},
						{
							"key": "password",
							"value": "password",
							"type": "default",
							"description": "The password associated with the provided email. Example: 'password'."
						}
					]
				},
				"url": {
					"raw": "http://web.test/api/v1/auth/login",
