#!/bin/bash

# Check if arguments are passed
if [ "$#" -eq 0 ]; then
    echo "Error: No arguments provided."
    exit 1
fi

# Display the command being run
echo "Running: docker-compose -f ../Docker/docker-compose.yml exec workspace bash -c 'cd web && php artisan $*'"

# Execute the docker-compose command and capture output
docker-compose -f ../Docker/docker-compose.yml exec workspace bash -c "cd web && php artisan $*" 2>&1 | tee artisan_output.log

# Check if the command was successful using a different method for error checking
EXIT_CODE=$?
if [ $EXIT_CODE -ne 0 ]; then
    echo "Error: artisan command failed with exit code $EXIT_CODE."
    exit $EXIT_CODE
else
    echo "artisan command executed successfully."
fi
