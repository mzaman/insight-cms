				"method": "POST",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "default",
						"description": "Indicates that the response should be in JSON format."
					}
				],
				"body": {
					"mode": "formdata",
					"formdata": [
						{
							"key": "name",
							"value": "TestUser",
							"type": "default",
							"description": "The full name of the user being registered. Example: 'TestUser'."
						},
						{
							"key": "password",
							"value": "password",
							"type": "default",
							"description": "The password for the user. Example: 'password'."
						},
						{
							"key": "email",
							"value": "user3@mail.com",
							"type": "default",
							"description": "The email address of the user. Example: 'user3@mail.com'."
						},
						{
							"key": "role_id",
							"value": "4",
							"type": "default",
							"description": "The ID of the role to be assigned to the user. Example: '4'."
						}
					]
				},
				"url": {
					"raw": "http://web.test/api/v1/auth/register",
