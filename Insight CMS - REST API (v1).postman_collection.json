	"item": [
		{
			"name": "Create NewsAPI Key",
			"description": "Generates a new API key for accessing the News API. The API key is used for making requests to fetch news articles.",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "default",
						"description": "Indicates that the response should be in JSON format."
					}
				],
				"body": {
					"mode": "formdata",
					"formdata": [
						{
							"key": "service_name",
							"value": "News API2",
							"type": "default",
							"description": "The name of the service for which the API key is being created. Example: 'News API2'."
						},
						{
							"key": "api_key",
							"value": "<API_KEY>",
							"type": "default",
							"description": "A unique API key used for accessing the News API. This key should be kept secure."
						}
					]
				},
				"url": {
					"raw": "http://web.test/api/v1/api-key",
					"protocol": "http",
					"host": [
						"web",
						"test"
					],
					"path": [
						"api",
						"v1",
						"api-key"
					]
				}
			},
			"response": []
		},
		{
			"name": "Register",
			"description": "Registers a new user in the system. The user will need to provide a name, password, email, and role ID.",
